  "keyFeatures": [
    "Fair and reproducible benchmarks beyond DFT error metrics",
    "Unified interface for 15+ foundation MLIP models (MACE-MP, CHGNet, M3GNet, SevenNet, ORB, eqV2, and more)",
    "Prefect-powered workflow orchestration for parallel benchmark execution at HPC scale",
    "Physical soundness tests: homonuclear diatomics, equation of state, energy conservation, force equivariance",
    "Molecular dynamics benchmarks: MD stability and combustion reactions",
    "Modular task system: OPT, EOS, MD, PHONON, NEB, ELASTICITY",
    "Streamlit leaderboard with real-time benchmark results on Hugging Face Spaces",
    "NeurIPS 2025 Spotlight paper recognition",
    "HuggingFace model hub integration for easy model contribution"
  ],
  "publicApiSurface": [
    "MLIPEnum — Enum of all available MLIP models",
    "MLIPMap — Dict mapping model names to calculator classes",
    "MLIP — Base class for HuggingFace-integrated MLIP models",
    "MLIPCalculator — ASE Calculator base class for MLIPs",
    "mlip_arena.tasks.OPT — Structure optimization task",
    "mlip_arena.tasks.EOS — Equation of state task",
    "mlip_arena.tasks.MD — Molecular dynamics task",
    "mlip_arena.tasks.PHONON — Phonon calculation task",
    "mlip_arena.tasks.NEB — Nudged elastic band task",
    "mlip_arena.tasks.NEB_FROM_ENDPOINTS — NEB with image interpolation",
    "mlip_arena.tasks.ELASTICITY — Elastic tensor calculation task",
    "mlip_arena.tasks.utils.get_calculator — Get calculator for a given model"
  ]
